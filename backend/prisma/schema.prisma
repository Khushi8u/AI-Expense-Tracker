// EcoSpend AI - Sustainable Expense Tracker
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  name              String
  email             String    @unique
  password          String
  profileImage      String?
  monthlyIncome     Float     @default(0)
  savingsGoal       Float     @default(0)
  preferredCurrency String    @default("USD")
  resetToken        String?
  resetTokenExpiry  DateTime?
  isVerified        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  expenses            Expense[]
  budgets             Budget[]
  notifications       Notification[]
  recurringExpenses   RecurringExpense[]
  aiInsights          AiInsight[]
  reports             Report[]
  sustainabilityScores SustainabilityScore[]
  carbonFootprints    CarbonFootprint[]
  greenGoals          GreenGoal[]
  ecoReports          EcoReport[]

  @@map("users")
}

model Expense {
  id              String        @id @default(uuid())
  userId          String
  title           String
  amount          Float
  category        Category      @default(OTHERS)
  paymentMethod   PaymentMethod @default(CASH)
  merchantName    String?
  date            DateTime      @default(now())
  notes           String?
  isRecurring     Boolean       @default(false)
  receiptImage    String?
  aiConfidence    Float?
  aiCategory      String?
  ocrText         String?
  // Sustainability fields
  ecoTag          EcoTag?
  carbonKg        Float?        // Estimated CO2 in kg
  isSustainable   Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("expenses")
  @@index([userId])
  @@index([date])
  @@index([category])
}

model Budget {
  id          String   @id @default(uuid())
  userId      String
  month       Int
  year        Int
  totalBudget Float    @default(0)
  spent       Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryBudgets CategoryBudget[]

  @@unique([userId, month, year])
  @@map("budgets")
}

model CategoryBudget {
  id        String   @id @default(uuid())
  budgetId  String
  category  Category
  limit     Float
  spent     Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budget    Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@unique([budgetId, category])
  @@map("category_budgets")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
  @@index([userId])
}

model RecurringExpense {
  id           String    @id @default(uuid())
  userId       String
  title        String
  amount       Float
  category     Category
  merchantName String?
  frequency    Frequency
  nextDueDate  DateTime
  lastPaidDate DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("recurring_expenses")
  @@index([userId])
}

model AiInsight {
  id          String      @id @default(uuid())
  userId      String
  type        InsightType
  title       String
  description String
  data        Json?
  month       Int
  year        Int
  createdAt   DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_insights")
  @@index([userId])
}

model Report {
  id        String     @id @default(uuid())
  userId    String
  month     Int
  year      Int
  type      ReportType
  fileUrl   String?
  data      Json?
  createdAt DateTime   @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reports")
  @@index([userId])
}

// =================== SUSTAINABILITY MODELS ===================

model SustainabilityScore {
  id              String   @id @default(uuid())
  userId          String
  month           Int
  year            Int
  score           Float    @default(0)   // 0-100
  positivePoints  Float    @default(0)
  negativePoints  Float    @default(0)
  breakdown       Json?    // category-wise scoring
  suggestions     Json?    // improvement suggestions
  trend           Float?   // vs last month (+/-)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@map("sustainability_scores")
  @@index([userId])
}

model CarbonFootprint {
  id                  String   @id @default(uuid())
  userId              String
  month               Int
  year                Int
  totalCarbonKg       Float    @default(0)
  transportCarbonKg   Float    @default(0)
  foodCarbonKg        Float    @default(0)
  shoppingCarbonKg    Float    @default(0)
  utilityCarbonKg     Float    @default(0)
  otherCarbonKg       Float    @default(0)
  breakdown           Json?
  reductionSuggestions Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@map("carbon_footprints")
  @@index([userId])
}

model GreenGoal {
  id              String         @id @default(uuid())
  userId          String
  title           String
  description     String?
  goalType        GreenGoalType
  targetValue     Float
  currentValue    Float          @default(0)
  unit            String         @default("%")
  deadline        DateTime?
  isCompleted     Boolean        @default(false)
  completedAt     DateTime?
  actionPlan      Json?          // AI-generated steps
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("green_goals")
  @@index([userId])
}

model EcoReport {
  id                    String   @id @default(uuid())
  userId                String
  month                 Int
  year                  Int
  sustainabilityScore   Float    @default(0)
  totalCarbonKg         Float    @default(0)
  carbonReductionKg     Float    @default(0)
  moneySaved            Float    @default(0)
  sustainableChoices    Int      @default(0)
  areasToImprove        Json?
  habitsImproved        Json?
  recommendations       Json?
  fileUrl               String?
  createdAt             DateTime @default(now())

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@map("eco_reports")
  @@index([userId])
}

// =================== ENUMS ===================

enum Category {
  FOOD
  TRAVEL
  SHOPPING
  ENTERTAINMENT
  BILLS
  HEALTHCARE
  EDUCATION
  INVESTMENTS
  GROCERIES
  SUBSCRIPTIONS
  OTHERS
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  UPI
  NET_BANKING
  WALLET
  CRYPTO
  OTHER
}

enum NotificationType {
  BUDGET_EXCEEDED
  OVERSPENDING
  SUBSCRIPTION_RENEWAL
  RECURRING_BILL
  MONTHLY_REPORT
  SAVINGS_GOAL
  GENERAL
  ECO_ALERT
  GREEN_GOAL_ACHIEVED
  SUSTAINABILITY_TIP
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum InsightType {
  SPENDING_SUMMARY
  SAVINGS_SUGGESTION
  BUDGET_WARNING
  HEALTH_SCORE
  OVERSPENDING_ALERT
  MONTHLY_ANALYSIS
  BEHAVIOR_INSIGHT
  ECO_INSIGHT
  CARBON_ALERT
  GREEN_RECOMMENDATION
}

enum ReportType {
  PDF
  CSV
  JSON
  ECO_PDF
  ECO_JSON
}

enum EcoTag {
  PUBLIC_TRANSPORT
  LOCAL_SHOPPING
  SUSTAINABLE_FOOD
  REUSABLE_PRODUCTS
  GREEN_ENERGY
  FAST_FASHION
  FOOD_DELIVERY
  RIDE_HAILING
  IMPULSE_SHOPPING
  EXCESSIVE_UTILITY
  NEUTRAL
}

enum GreenGoalType {
  REDUCE_FOOD_DELIVERY
  USE_PUBLIC_TRANSPORT
  REDUCE_FAST_FASHION
  REDUCE_IMPULSE_SHOPPING
  LOWER_CARBON_FOOTPRINT
  INCREASE_LOCAL_SHOPPING
  REDUCE_SINGLE_USE
  CUSTOM
}
